# Dependencies
node_modules/
**/node_modules/

# Environment variables
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Build output
dist/
dist-ssr/
build/
**/dist/
**/dist-ssr/
**/build/

# Prisma generated client (in case a custom output path is used)
generated/
**/generated/prisma/

# Uploaded files (keep folder structure, ignore contents)
Backend/uploads/fotos/*
!Backend/uploads/fotos/.gitkeep

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Local-only Claude Code settings
.claude/settings.local.json

# Misc
*.local
