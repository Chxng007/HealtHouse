generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoDocumento {
  CC
  CE
  PA
  TI
  RC
  PE
  PPT
}

enum Sexo {
  masculino
  femenino
  intersexual
}

enum EstadoCivil {
  soltero
  casado
  union_libre
  separado
  divorciado
  viudo
}

enum GrupoSanguineo {
  A
  B
  AB
  O
}

enum Rh {
  positivo
  negativo
}

enum Regimen {
  contributivo
  subsidiado
  especial
  particular
}

enum Zona {
  urbana
  rural
}

enum EstadoCita {
  agendada
  confirmada
  en_atencion
  atendida
  cancelada
  no_asistio
}

enum CanalRecordatorio {
  sms
  email
}

enum EstadoRecordatorio {
  pendiente
  enviado_stub
  fallido
}

enum TipoAtencion {
  consulta
  procedimiento
  urgencia
}

enum EstadoAdmision {
  en_espera
  en_atencion
  atendido
  cancelado
}

enum EstadoAtencion {
  en_curso
  cerrada
  anulada
}

enum TipoDiagnostico {
  principal
  secundario
  complicacion
}

enum CondicionDiagnostico {
  confirmado
  impresion_diagnostica
}

enum EstadoDocumentoClinico {
  emitido
  anulado
}

enum PrioridadOrden {
  rutinaria
  prioritaria
}

enum EstadoConsentimiento {
  pendiente
  firmado
  anulado
}

enum TipoContrato {
  evento
  capitacion
  paquete
}

enum EstadoFactura {
  borrador
  emitida
  pagada
  anulada
  en_glosa
}

enum TipoNotaFactura {
  credito
  debito
}

enum MetodoPago {
  efectivo
  tarjeta
  transferencia
}

enum EstadoCierreCaja {
  abierta
  cerrada
}

enum EstadoRips {
  generado
  validado_ok
  validado_con_errores
}

enum ModuloPermiso {
  pacientes
  historia_clinica
  agenda
  formulas_ordenes
  reportes
  administracion
}

model Role {
  id        String   @id @default(cuid())
  nombre    String   @unique
  slug      String   @unique
  icono     String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  permisos  RolePermission[]

  @@map("roles")
}

model Sede {
  id                 String     @id @default(cuid())
  nombre             String
  ciudad             String
  esPrincipal        Boolean    @default(false)
  activa             Boolean    @default(true)
  direccion          String?
  telefono           String?
  codigoHabilitacion String?
  horarios           Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  usuarios    UserSede[]
  pacientesRegistrados Paciente[]
  consultorios Consultorio[]
  citas        Cita[]
  admisiones   Admision[]
  atenciones   Atencion[]
  formulas       Formula[]
  ordenes        Orden[]
  remisiones     Remision[]
  incapacidades  Incapacidad[]
  consentimientos Consentimiento[]
  facturas       Factura[]
  cierresCaja    CierreCaja[]
  ripsExports    RipsExport[]

  @@map("sedes")
}

model Eps {
  id        String     @id @default(cuid())
  codigo    String     @unique
  nombre    String     @unique
  activa    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  pacientes Paciente[]
  admisiones Admision[]
  convenios Convenio[]

  @@map("eps")
}

model Paciente {
  id              String          @id @default(cuid())
  tipoDocumento   TipoDocumento
  numeroDocumento String          @unique
  nombres         String
  apellidos       String
  fechaNacimiento DateTime        @db.Date
  sexo            Sexo
  estadoCivil     EstadoCivil?
  ocupacion       String?
  grupoSanguineo  GrupoSanguineo?
  rh              Rh?
  telefono        String
  correo          String?
  direccion       String
  municipio       String
  zona            Zona            @default(urbana)
  epsId           String
  eps             Eps             @relation(fields: [epsId], references: [id])
  regimen         Regimen
  nroAfiliacion   String?
  sedeRegistroId  String?
  sedeRegistro    Sede?           @relation(fields: [sedeRegistroId], references: [id])
  fotoUrl         String?
  activo          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  contactos  ContactoEmergencia[]
  citas      Cita[]
  admisiones Admision[]
  atenciones Atencion[]
  formulas       Formula[]
  ordenes        Orden[]
  remisiones     Remision[]
  incapacidades  Incapacidad[]
  consentimientos Consentimiento[]
  facturas       Factura[]

  @@index([apellidos, nombres])
  @@map("pacientes")
}

model ContactoEmergencia {
  id         String   @id @default(cuid())
  pacienteId String
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  nombre     String
  parentesco String
  telefono   String
  direccion  String?

  @@map("contactos_emergencia")
}

model Especialidad {
  id           String        @id @default(cuid())
  codigo       String?       @unique
  nombre       String        @unique
  activa       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  consultorios Consultorio[]

  @@map("especialidades")
}

model Consultorio {
  id             String        @id @default(cuid())
  nombre         String
  sedeId         String
  sede           Sede          @relation(fields: [sedeId], references: [id])
  especialidadId String?
  especialidad   Especialidad? @relation(fields: [especialidadId], references: [id])
  medicoId       String?
  medico         User?         @relation("ConsultorioMedico", fields: [medicoId], references: [id])
  activo         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  citas          Cita[]

  @@map("consultorios")
}

model Cita {
  id                   String     @id @default(cuid())
  pacienteId           String
  paciente             Paciente   @relation(fields: [pacienteId], references: [id])
  medicoId             String
  medico               User       @relation("CitasMedico", fields: [medicoId], references: [id])
  consultorioId        String
  consultorio          Consultorio @relation(fields: [consultorioId], references: [id])
  sedeId               String
  sede                 Sede       @relation(fields: [sedeId], references: [id])
  inicio               DateTime
  fin                  DateTime
  estado               EstadoCita @default(agendada)
  motivo               String?
  notas                String?
  motivoCancelacion    String?
  motivoReprogramacion String?
  reprogramadaDeId     String?    @unique
  reprogramadaDe       Cita?      @relation("Reprogramacion", fields: [reprogramadaDeId], references: [id])
  reprogramadaA        Cita?      @relation("Reprogramacion")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  recordatorios Recordatorio[]
  admision      Admision?

  @@index([medicoId, inicio])
  @@index([consultorioId, inicio])
  @@index([sedeId, inicio])
  @@map("citas")
}

model Admision {
  id                 String         @id @default(cuid())
  pacienteId         String
  paciente           Paciente       @relation(fields: [pacienteId], references: [id])
  citaId             String?        @unique
  cita               Cita?          @relation(fields: [citaId], references: [id])
  sedeId             String
  sede               Sede           @relation(fields: [sedeId], references: [id])
  medicoId           String
  medico             User           @relation("AdmisionesMedico", fields: [medicoId], references: [id])
  tipoAtencion       TipoAtencion
  epsId              String?
  eps                Eps?           @relation(fields: [epsId], references: [id])
  regimen            Regimen?
  numeroAutorizacion String?
  copago             Decimal?       @db.Decimal(12, 2)
  estado             EstadoAdmision @default(en_espera)
  horaLlegada        DateTime       @default(now())
  observaciones      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  atencion Atencion?
  facturas Factura[]

  @@index([sedeId, horaLlegada])
  @@map("admisiones")
}

model Cie10 {
  id          String  @id @default(cuid())
  codigo      String  @unique
  descripcion String
  activo      Boolean @default(true)

  diagnosticos AtencionDiagnostico[]
  incapacidades Incapacidad[]

  @@map("cie10")
}

model Atencion {
  id                        String         @id @default(cuid())
  pacienteId                String
  paciente                  Paciente       @relation(fields: [pacienteId], references: [id])
  admisionId                String?        @unique
  admision                  Admision?      @relation(fields: [admisionId], references: [id])
  medicoId                  String
  medico                    User           @relation("AtencionesMedico", fields: [medicoId], references: [id])
  sedeId                    String
  sede                      Sede           @relation(fields: [sedeId], references: [id])
  fecha                     DateTime       @default(now())
  motivoConsulta            String
  enfermedadActual          String?
  antecedentesPersonales    String?
  antecedentesFamiliares    String?
  antecedentesFarmacologicos String?
  examenFisico              String?
  planManejo                String?
  estado                    EstadoAtencion @default(en_curso)
  cerradaAt                 DateTime?
  anuladaMotivo             String?
  anuladaAt                 DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  signosVitales SignosVitales?
  diagnosticos  AtencionDiagnostico[]
  formulas       Formula[]
  ordenes        Orden[]
  remisiones     Remision[]
  incapacidades  Incapacidad[]
  consentimientos Consentimiento[]

  @@index([pacienteId, fecha])
  @@map("atenciones")
}

model SignosVitales {
  id           String   @id @default(cuid())
  atencionId   String   @unique
  atencion     Atencion @relation(fields: [atencionId], references: [id], onDelete: Cascade)
  taSistolica  Int?
  taDiastolica Int?
  fc           Int?
  fr           Int?
  temperatura  Decimal? @db.Decimal(4, 1)
  peso         Decimal? @db.Decimal(5, 2)
  talla        Decimal? @db.Decimal(5, 2)
  imc          Decimal? @db.Decimal(4, 1)
  spo2         Int?

  @@map("signos_vitales")
}

model AtencionDiagnostico {
  id         String               @id @default(cuid())
  atencionId String
  atencion   Atencion             @relation(fields: [atencionId], references: [id], onDelete: Cascade)
  cie10Id    String
  cie10      Cie10                @relation(fields: [cie10Id], references: [id])
  tipo       TipoDiagnostico
  condicion  CondicionDiagnostico

  @@unique([atencionId, cie10Id])
  @@map("atencion_diagnosticos")
}

model Recordatorio {
  id             String             @id @default(cuid())
  citaId         String
  cita           Cita               @relation(fields: [citaId], references: [id], onDelete: Cascade)
  canal          CanalRecordatorio
  estado         EstadoRecordatorio @default(pendiente)
  programadoPara DateTime
  enviadoAt      DateTime?
  detalle        Json?

  @@map("recordatorios")
}

model User {
  id                 String        @id @default(cuid())
  nombres            String
  apellidos          String
  tipoDocumento      TipoDocumento
  numeroDocumento    String        @unique
  correo             String        @unique
  telefono           String?
  cargoProfesion     String
  rolId              String
  rol                Role          @relation(fields: [rolId], references: [id])
  activo             Boolean       @default(true)
  fotoUrl            String?
  passwordHash       String
  mustChangePassword Boolean       @default(true)
  lastAccess         DateTime?
  failedAttempts     Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  sedes    UserSede[]
  permisos UserPermission[]
  consultoriosAsignados Consultorio[] @relation("ConsultorioMedico")
  citasComoMedico       Cita[]        @relation("CitasMedico")
  admisionesComoMedico  Admision[]    @relation("AdmisionesMedico")
  atencionesComoMedico  Atencion[]    @relation("AtencionesMedico")
  formulasComoMedico        Formula[]        @relation("FormulasMedico")
  ordenesComoMedico         Orden[]          @relation("OrdenesMedico")
  remisionesComoMedico      Remision[]       @relation("RemisionesMedico")
  incapacidadesComoMedico   Incapacidad[]    @relation("IncapacidadesMedico")
  consentimientosComoMedico Consentimiento[] @relation("ConsentimientosMedico")

  @@map("users")
}

model UserSede {
  userId String
  sedeId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sede   Sede @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@id([userId, sedeId])
  @@map("user_sedes")
}

model UserPermission {
  id       String        @id @default(cuid())
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  modulo   ModuloPermiso
  ver      Boolean       @default(false)
  crear    Boolean       @default(false)
  editar   Boolean       @default(false)
  eliminar Boolean       @default(false)
  imprimir Boolean       @default(false)
  exportar Boolean       @default(false)

  @@unique([userId, modulo])
  @@map("user_permissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  accion    String
  entidad   String
  entidadId String
  detalle   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model RolePermission {
  id       String        @id @default(cuid())
  rolId    String
  rol      Role          @relation(fields: [rolId], references: [id], onDelete: Cascade)
  modulo   ModuloPermiso
  ver      Boolean       @default(false)
  crear    Boolean       @default(false)
  editar   Boolean       @default(false)
  eliminar Boolean       @default(false)
  imprimir Boolean       @default(false)
  exportar Boolean       @default(false)

  @@unique([rolId, modulo])
  @@map("role_permissions")
}

model Cups {
  id         String      @id @default(cuid())
  codigo     String      @unique
  nombre     String
  activo     Boolean     @default(true)
  ordenItems OrdenItem[]

  @@map("cups")
}

model Formula {
  id            String                 @id @default(cuid())
  pacienteId    String
  paciente      Paciente               @relation(fields: [pacienteId], references: [id])
  atencionId    String?
  atencion      Atencion?              @relation(fields: [atencionId], references: [id])
  medicoId      String
  medico        User                   @relation("FormulasMedico", fields: [medicoId], references: [id])
  sedeId        String
  sede          Sede                   @relation(fields: [sedeId], references: [id])
  fecha         DateTime               @default(now())
  estado        EstadoDocumentoClinico @default(emitido)
  anuladaMotivo String?
  anuladaAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  items FormulaItem[]

  @@index([pacienteId, fecha])
  @@map("formulas")
}

model FormulaItem {
  id          String  @id @default(cuid())
  formulaId   String
  formula     Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  medicamento String
  dosis       String
  frecuencia  String
  duracion    String

  @@map("formula_items")
}

model Orden {
  id            String                 @id @default(cuid())
  pacienteId    String
  paciente      Paciente               @relation(fields: [pacienteId], references: [id])
  atencionId    String?
  atencion      Atencion?              @relation(fields: [atencionId], references: [id])
  medicoId      String
  medico        User                   @relation("OrdenesMedico", fields: [medicoId], references: [id])
  sedeId        String
  sede          Sede                   @relation(fields: [sedeId], references: [id])
  fecha         DateTime               @default(now())
  estado        EstadoDocumentoClinico @default(emitido)
  anuladaMotivo String?
  anuladaAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  items OrdenItem[]

  @@index([pacienteId, fecha])
  @@map("ordenes")
}

model OrdenItem {
  id        String         @id @default(cuid())
  ordenId   String
  orden     Orden          @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  cupsId    String
  cups      Cups           @relation(fields: [cupsId], references: [id])
  prioridad PrioridadOrden @default(rutinaria)

  @@map("orden_items")
}

model Remision {
  id                  String                 @id @default(cuid())
  pacienteId          String
  paciente            Paciente               @relation(fields: [pacienteId], references: [id])
  atencionId          String?
  atencion            Atencion?              @relation(fields: [atencionId], references: [id])
  medicoId            String
  medico              User                   @relation("RemisionesMedico", fields: [medicoId], references: [id])
  sedeId              String
  sede                Sede                   @relation(fields: [sedeId], references: [id])
  fecha               DateTime               @default(now())
  especialidadDestino String
  ipsDestino          String
  justificacion       String
  estado              EstadoDocumentoClinico @default(emitido)
  anuladaMotivo       String?
  anuladaAt           DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([pacienteId, fecha])
  @@map("remisiones")
}

model Incapacidad {
  id            String                 @id @default(cuid())
  pacienteId    String
  paciente      Paciente               @relation(fields: [pacienteId], references: [id])
  atencionId    String?
  atencion      Atencion?              @relation(fields: [atencionId], references: [id])
  medicoId      String
  medico        User                   @relation("IncapacidadesMedico", fields: [medicoId], references: [id])
  sedeId        String
  sede          Sede                   @relation(fields: [sedeId], references: [id])
  fecha         DateTime               @default(now())
  cie10Id       String
  cie10         Cie10                  @relation(fields: [cie10Id], references: [id])
  numeroDias    Int
  fechaInicio   DateTime               @db.Date
  fechaFin      DateTime               @db.Date
  estado        EstadoDocumentoClinico @default(emitido)
  anuladaMotivo String?
  anuladaAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([pacienteId, fecha])
  @@map("incapacidades")
}

model Consentimiento {
  id            String               @id @default(cuid())
  pacienteId    String
  paciente      Paciente             @relation(fields: [pacienteId], references: [id])
  atencionId    String?
  atencion      Atencion?            @relation(fields: [atencionId], references: [id])
  medicoId      String
  medico        User                 @relation("ConsentimientosMedico", fields: [medicoId], references: [id])
  sedeId        String
  sede          Sede                 @relation(fields: [sedeId], references: [id])
  fecha         DateTime             @default(now())
  procedimiento String
  firmante      String               @default("Paciente")
  estado        EstadoConsentimiento @default(pendiente)
  firmaUrl      String?
  anuladaMotivo String?
  anuladaAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([pacienteId, fecha])
  @@map("consentimientos")
}

model Convenio {
  id           String       @id @default(cuid())
  epsId        String
  eps          Eps          @relation(fields: [epsId], references: [id])
  tipoContrato TipoContrato
  activo       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tarifas  Tarifa[]
  facturas Factura[]

  @@unique([epsId, tipoContrato])
  @@map("convenios")
}

model Servicio {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  valorBase Decimal  @db.Decimal(12, 2)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tarifas      Tarifa[]
  facturaItems FacturaItem[]

  @@map("servicios")
}

model Tarifa {
  id         String   @id @default(cuid())
  convenioId String
  convenio   Convenio @relation(fields: [convenioId], references: [id])
  servicioId String
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  valor      Decimal  @db.Decimal(12, 2)
  copago     Decimal  @db.Decimal(12, 2) @default(0)

  @@unique([convenioId, servicioId])
  @@map("tarifas")
}

model NumeracionFactura {
  id          String  @id @default(cuid())
  prefijo     String  @unique
  consecutivo Int     @default(0)
  rangoDesde  Int     @default(1)
  rangoHasta  Int     @default(999999)
  activa      Boolean @default(true)

  @@map("numeraciones_factura")
}

model Factura {
  id            String        @id @default(cuid())
  numero        String?       @unique
  pacienteId    String
  paciente      Paciente      @relation(fields: [pacienteId], references: [id])
  admisionId    String?
  admision      Admision?     @relation(fields: [admisionId], references: [id])
  convenioId    String
  convenio      Convenio      @relation(fields: [convenioId], references: [id])
  sedeId        String
  sede          Sede          @relation(fields: [sedeId], references: [id])
  fecha         DateTime      @default(now())
  subtotal      Decimal       @db.Decimal(12, 2) @default(0)
  copago        Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2) @default(0)
  estado        EstadoFactura @default(borrador)
  // STUB integración Siigo/DIAN: sin llamado externo real, solo el estado persistido.
  estadoDian    String        @default("pendiente_emision")
  anuladaMotivo String?
  anuladaAt     DateTime?
  glosaMotivo   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items FacturaItem[]
  notas NotaFactura[]
  pagos Pago[]

  @@index([pacienteId, fecha])
  @@map("facturas")
}

model FacturaItem {
  id            String   @id @default(cuid())
  facturaId     String
  factura       Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  servicioId    String
  servicio      Servicio @relation(fields: [servicioId], references: [id])
  cantidad      Int      @default(1)
  valorUnitario Decimal  @db.Decimal(12, 2)
  valorTotal    Decimal  @db.Decimal(12, 2)

  @@map("factura_items")
}

model NotaFactura {
  id        String          @id @default(cuid())
  facturaId String
  factura   Factura         @relation(fields: [facturaId], references: [id])
  tipo      TipoNotaFactura
  valor     Decimal         @db.Decimal(12, 2)
  motivo    String
  createdAt DateTime        @default(now())

  @@map("notas_factura")
}

model Pago {
  id           String      @id @default(cuid())
  facturaId    String
  factura      Factura     @relation(fields: [facturaId], references: [id])
  reciboNumero String      @unique
  metodo       MetodoPago
  valor        Decimal     @db.Decimal(12, 2)
  cierreCajaId String?
  cierreCaja   CierreCaja? @relation(fields: [cierreCajaId], references: [id])
  createdAt    DateTime    @default(now())

  @@map("pagos")
}

model CierreCaja {
  id             String           @id @default(cuid())
  sedeId         String
  sede           Sede             @relation(fields: [sedeId], references: [id])
  fecha          DateTime         @default(now())
  baseInicial    Decimal          @db.Decimal(12, 2)
  totalRecaudado Decimal          @db.Decimal(12, 2) @default(0)
  egresos        Decimal          @db.Decimal(12, 2) @default(0)
  totalCaja      Decimal          @db.Decimal(12, 2) @default(0)
  estado         EstadoCierreCaja @default(cerrada)
  cerradaAt      DateTime?
  createdAt      DateTime         @default(now())

  pagos Pago[]

  @@map("cierres_caja")
}

model Configuracion {
  clave String @id
  valor Json

  @@map("configuracion")
}

model RipsExport {
  id                String     @id @default(cuid())
  sedeId            String?
  sede              Sede?      @relation(fields: [sedeId], references: [id])
  desde             DateTime   @db.Date
  hasta             DateTime   @db.Date
  // Estructura fiel a la Res. 2275/2023 (usuarios US, consultas AC, procedimientos AP)
  // sobre un subconjunto representativo de campos, no el Anexo Técnico completo.
  contenido         Json
  totalRegistros    Int        @default(0)
  erroresValidacion Json
  estado            EstadoRips @default(generado)
  createdAt         DateTime   @default(now())

  @@map("rips_exports")
}
